<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ask Question</title>
  <link rel="stylesheet" href="/css/article/form_new.css">
</head>

<body>
<%- include('../nav_bar') %>
<div class="container">
  <div class="card">
    <h2>Ask a Question</h2>
    <p class="subtitle">Share your problem with the community.</p>
    <form action="/article/new" method="POST"> 
      <label>Question Title</label>
      <div class="input-group">
        <input type="text" name="title" placeholder="How can i learn CSS?">
      </div>
      <label>Description</label>
      <div class="input-group textarea-group">
        <textarea name="content" placeholder="Describe your problem in detail"></textarea>
      </div>
      <button class="primary-btn">Post Question</button>
    </form>
  </div>
</div>
</body>
</html>